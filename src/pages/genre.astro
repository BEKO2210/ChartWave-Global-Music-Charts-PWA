---
import BaseLayout from '@components/layout/BaseLayout.astro';
import ChartGrid from '@components/charts/ChartGrid.astro';
import PlayerIsland from '@components/player/PlayerIsland.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('charts');
const genreCharts = entries
  .map((e) => e.data)
  .filter((c) => c.type === 'genre');
---

<BaseLayout
  title="Genre Charts | ChartWave"
  description="Browse music charts by genre — Pop, Hip-Hop, Rock, Electronic, and more."
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <h1 class="mb-2 text-3xl font-bold text-balance">Genre Charts</h1>
    <p class="mb-8 text-[var(--text-secondary)]">
      Explore the top tracks across every genre, updated daily.
    </p>

    <ChartGrid charts={genreCharts} />
  </div>
  <PlayerIsland />
</BaseLayout>
