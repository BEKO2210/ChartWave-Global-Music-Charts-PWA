---
import BaseLayout from '@components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Offline | ChartWave"
  description="You are currently offline. Some cached content may be available."
>
  <div class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6">
    <div class="mb-6">
      <svg class="mx-auto h-16 w-16 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 12 7 4.7C8.7 2.7 11.2 1.5 14 1.5c5 0 9.1 3.7 9.8 8.5" />
        <path d="M5 12.8C5.7 11.1 7.1 9.8 8.8 9.2" />
        <path d="m2 2 20 20" />
        <circle cx="12" cy="18" r="1" />
      </svg>
    </div>

    <h1 class="mb-4 text-3xl font-bold text-balance">You're offline</h1>
    <p class="mb-8 text-lg text-[var(--text-secondary)]">
      It looks like you've lost your internet connection.
      Previously cached charts and previews are still available.
    </p>

    <a
      href="/chartwave/"
      class="inline-flex items-center gap-2 rounded-lg bg-[var(--brand)] px-6 py-3 font-medium text-white transition-colors hover:bg-[var(--brand-hover)]"
    >
      Go to Home
    </a>
  </div>
</BaseLayout>
