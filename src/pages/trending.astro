---
import BaseLayout from '@components/layout/BaseLayout.astro';
import TrackList from '@components/tracks/TrackList.astro';
import PlayerIsland from '@components/player/PlayerIsland.astro';
import { getCollection } from 'astro:content';
import type { Track } from '../content/config';

const entries = await getCollection('charts');
const allTracks: Track[] = [];

for (const entry of entries) {
  for (const track of entry.data.tracks) {
    if (track.rankChange === 'up' && track.rankDelta != null && track.rankDelta > 0) {
      // Avoid duplicates by track id
      if (!allTracks.some((t) => t.id === track.id)) {
        allTracks.push(track);
      }
    }
  }
}

// Sort by biggest positive rank delta
const trending = allTracks
  .sort((a, b) => (b.rankDelta ?? 0) - (a.rankDelta ?? 0))
  .slice(0, 50)
  .map((track, i) => ({ ...track, rank: i + 1 }));
---

<BaseLayout
  title="Trending Now | ChartWave"
  description="The biggest chart climbers right now — tracks making the biggest moves across all charts."
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <div class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-balance">Trending Now</h1>
      <p class="text-[var(--text-secondary)]">
        The biggest chart climbers right now. Tracks making the biggest moves across all charts.
      </p>
    </div>

    {trending.length > 0 ? (
      <TrackList tracks={trending} showHeader={true} />
    ) : (
      <div class="rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-surface)] p-12 text-center">
        <p class="text-[var(--text-muted)]">No trending tracks at the moment. Check back after the next chart update.</p>
      </div>
    )}
  </div>
  <PlayerIsland />
</BaseLayout>
