---
interface Props {
  variant?: 'default' | 'brand' | 'success' | 'warning' | 'danger';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant = 'default', size = 'sm', class: className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--bg-elevated)] text-[var(--text-secondary)] border border-[var(--border-subtle)]',
  brand: 'bg-[var(--brand)]/10 text-[var(--text-accent)] border border-[var(--border-accent)]',
  success: 'bg-green-500/10 text-green-400 border border-green-500/20',
  warning: 'bg-amber-500/10 text-amber-400 border border-amber-500/20',
  danger: 'bg-red-500/10 text-red-400 border border-red-500/20',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-2.5 py-1 text-sm',
};
---

<span class:list={['inline-flex items-center rounded-full font-medium', variantClasses[variant], sizeClasses[size], className]}>
  <slot />
</span>
