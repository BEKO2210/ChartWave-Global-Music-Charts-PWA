---
import ProgressBar from './ProgressBar.astro';
---

<div
  id="mini-player"
  class="glass-player fixed bottom-0 left-0 right-0 z-50 hidden"
  role="region"
  aria-label="Music player"
>
  <!-- Progress bar at top -->
  <ProgressBar class="absolute top-0 left-0 right-0" />

  <div class="mx-auto flex h-[72px] max-w-7xl items-center gap-3 px-4 pt-[3px] md:h-[80px] md:gap-4">
    <!-- Artwork + Info -->
    <div class="flex min-w-0 items-center gap-3">
      <div class="relative h-11 w-11 flex-shrink-0 overflow-hidden rounded-lg bg-[var(--bg-elevated)] md:h-14 md:w-14">
        <img
          id="player-artwork"
          src=""
          alt=""
          width="56"
          height="56"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="min-w-0">
        <div id="player-title" class="truncate text-sm font-semibold text-[var(--text-primary)]">
          Not playing
        </div>
        <div id="player-artist" class="truncate text-xs text-[var(--text-secondary)]">
          &mdash;
        </div>
      </div>
    </div>

    <!-- Center controls -->
    <div class="flex flex-1 items-center justify-center gap-2 md:gap-3">
      <!-- Shuffle (desktop only) -->
      <button
        id="btn-shuffle"
        type="button"
        class="hidden rounded-full p-1.5 text-[var(--text-muted)] transition-colors hover:text-[var(--text-primary)] md:block"
        aria-label="Toggle shuffle"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22" /><path d="m18 2 4 4-4 4" /><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2" /><path d="M22 18h-5.9c-1.3 0-2.6-.7-3.3-1.8l-.5-.8" /><path d="m18 14 4 4-4 4" />
        </svg>
      </button>

      <!-- Previous -->
      <button
        id="btn-prev"
        type="button"
        class="hidden rounded-full p-1.5 text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] md:block"
        aria-label="Previous track"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z" />
        </svg>
      </button>

      <!-- Play/Pause -->
      <button
        id="btn-play"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--brand)] text-white shadow-lg transition-transform hover:scale-105 md:h-12 md:w-12"
        aria-label="Play"
      >
        <svg id="icon-play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
        <svg id="icon-pause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="hidden" aria-hidden="true">
          <path d="M6 4h4v16H6zm8 0h4v16h-4z" />
        </svg>
      </button>

      <!-- Next -->
      <button
        id="btn-next"
        type="button"
        class="rounded-full p-1.5 text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
        aria-label="Next track"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16 6h2v12h-2zm-2.5 6L5 6v12z" />
        </svg>
      </button>

      <!-- Repeat (desktop only) -->
      <button
        id="btn-repeat"
        type="button"
        class="hidden rounded-full p-1.5 text-[var(--text-muted)] transition-colors hover:text-[var(--text-primary)] md:block"
        aria-label="Toggle repeat"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m17 2 4 4-4 4" /><path d="M3 11v-1a4 4 0 0 1 4-4h14" /><path d="m7 22-4-4 4-4" /><path d="M21 13v1a4 4 0 0 1-4 4H3" />
        </svg>
      </button>
    </div>

    <!-- Time display (desktop only) -->
    <div class="hidden items-center gap-2 text-xs text-[var(--text-muted)] md:flex">
      <span id="player-time-current">0:00</span>
      <span>/</span>
      <span id="player-time-duration">0:30</span>
    </div>

    <!-- Volume (desktop only) -->
    <div class="hidden items-center gap-2 lg:flex">
      <button
        id="btn-mute"
        type="button"
        class="rounded-full p-1.5 text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
        aria-label="Toggle mute"
      >
        <svg id="icon-volume" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 5 6 9H2v6h4l5 4zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" />
        </svg>
        <svg id="icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
          <path d="M11 5 6 9H2v6h4l5 4zM22 9l-6 6M16 9l6 6" />
        </svg>
      </button>
      <input
        id="volume-slider"
        type="range"
        min="0"
        max="100"
        value="80"
        class="h-1 w-20 cursor-pointer appearance-none rounded-full bg-[var(--border-default)] accent-[var(--brand)]"
        aria-label="Volume"
      />
    </div>
  </div>
</div>

<script>
  import { audioPlayer } from '../../lib/audioPlayer';
  import {
    $currentTrack,
    $isPlaying,
    $isLoading,
    $progress,
    $currentTime,
    $duration,
    $volume,
    $isMuted,
    $repeatMode,
    $isShuffle,
  } from '../../stores/player';

  // DOM elements
  const player = document.getElementById('mini-player');
  const artwork = document.getElementById('player-artwork') as HTMLImageElement | null;
  const titleEl = document.getElementById('player-title');
  const artistEl = document.getElementById('player-artist');
  const btnPlay = document.getElementById('btn-play');
  const iconPlay = document.getElementById('icon-play');
  const iconPause = document.getElementById('icon-pause');
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  const btnShuffle = document.getElementById('btn-shuffle');
  const btnRepeat = document.getElementById('btn-repeat');
  const btnMute = document.getElementById('btn-mute');
  const iconVolume = document.getElementById('icon-volume');
  const iconMuted = document.getElementById('icon-muted');
  const volumeSlider = document.getElementById('volume-slider') as HTMLInputElement | null;
  const timeCurrent = document.getElementById('player-time-current');
  const timeDuration = document.getElementById('player-time-duration');
  const progressFill = document.getElementById('progress-fill');
  const progressHandle = document.getElementById('progress-handle');

  function formatTime(s: number): string {
    const sec = Math.floor(s);
    return `${Math.floor(sec / 60)}:${String(sec % 60).padStart(2, '0')}`;
  }

  // Show the player as soon as a track is selected
  $currentTrack.subscribe((track) => {
    if (!track) return;
    if (player) player.classList.remove('hidden');
    if (artwork) { artwork.src = track.artwork.medium; artwork.alt = `${track.title} artwork`; }
    if (titleEl) titleEl.textContent = track.title;
    if (artistEl) artistEl.textContent = track.artistName;
  });

  $isPlaying.subscribe((playing) => {
    if (iconPlay) iconPlay.classList.toggle('hidden', playing);
    if (iconPause) iconPause.classList.toggle('hidden', !playing);
    if (btnPlay) btnPlay.setAttribute('aria-label', playing ? 'Pause' : 'Play');
  });

  $progress.subscribe((p) => {
    if (progressFill) progressFill.style.width = `${p * 100}%`;
    if (progressHandle) progressHandle.style.left = `${p * 100}%`;
  });

  $currentTime.subscribe((t) => {
    if (timeCurrent) timeCurrent.textContent = formatTime(t);
  });

  $duration.subscribe((d) => {
    if (timeDuration) timeDuration.textContent = formatTime(d);
  });

  $isMuted.subscribe((muted) => {
    if (iconVolume) iconVolume.classList.toggle('hidden', muted);
    if (iconMuted) iconMuted.classList.toggle('hidden', !muted);
  });

  $volume.subscribe((v) => {
    if (volumeSlider) volumeSlider.value = String(Math.round(v * 100));
  });

  $isShuffle.subscribe((on) => {
    if (btnShuffle) btnShuffle.style.color = on ? 'var(--brand)' : '';
  });

  $repeatMode.subscribe((mode) => {
    if (btnRepeat) btnRepeat.style.color = mode !== 'none' ? 'var(--brand)' : '';
  });

  // Button event listeners
  btnPlay?.addEventListener('click', () => audioPlayer.toggle());
  btnPrev?.addEventListener('click', () => audioPlayer.playPrev());
  btnNext?.addEventListener('click', () => audioPlayer.playNext());
  btnShuffle?.addEventListener('click', () => $isShuffle.set(!$isShuffle.get()));
  btnRepeat?.addEventListener('click', () => {
    const modes: Array<'none' | 'one' | 'all'> = ['none', 'one', 'all'];
    const idx = modes.indexOf($repeatMode.get());
    const next = modes[(idx + 1) % modes.length];
    if (next != null) $repeatMode.set(next);
  });
  btnMute?.addEventListener('click', () => audioPlayer.toggleMute());
  volumeSlider?.addEventListener('input', () => {
    audioPlayer.setVolume(Number(volumeSlider.value) / 100);
  });

  // Listen for seek events from ProgressBar
  window.addEventListener('chartwave:seek', ((e: CustomEvent) => {
    audioPlayer.seek(e.detail.percent);
  }) as EventListener);

  // Initialize keyboard shortcuts
  import('../../lib/keyboard').then(({ initKeyboardShortcuts }) => {
    initKeyboardShortcuts();
  });
</script>
