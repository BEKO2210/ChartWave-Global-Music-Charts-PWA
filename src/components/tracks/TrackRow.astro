---
import type { Track } from '../../content/config';
import { formatNumber } from '@utils/format';
import RankBadge from './RankBadge.astro';
import ArtworkImage from './ArtworkImage.astro';

interface Props {
  track: Track;
  index?: number;
}

const { track, index } = Astro.props;

const rankDisplay = String(track.rank).padStart(3, '0');
const hasPreview = track.previewUrl !== null;
const genreTags = track.genres.slice(0, 2);
---

<div
  class="group flex items-center gap-3 rounded-lg px-3 py-2 transition-colors hover:bg-[var(--bg-hover)]"
  data-track-id={track.id}
  data-index={index}
  role="row"
>
  <!-- Rank number -->
  <span
    class="w-12 shrink-0 text-right font-mono text-sm font-bold text-[var(--text-muted)]"
    aria-label={`Rank ${track.rank}`}
  >
    {rankDisplay}
  </span>

  <!-- Rank change badge -->
  <span class="flex w-12 shrink-0 items-center justify-center">
    <RankBadge rankChange={track.rankChange} rankDelta={track.rankDelta} />
  </span>

  <!-- Artwork with play overlay -->
  <ArtworkImage
    src={track.artwork.medium}
    alt={`${track.title} by ${track.artistName}`}
    size="md"
    placeholder={track.artwork.placeholder}
  >
    {hasPreview && (
      <button
        type="button"
        class="absolute inset-0 flex items-center justify-center rounded-lg bg-black/60 opacity-0 transition-opacity group-hover:opacity-100"
        aria-label={`Play preview of ${track.title}`}
        data-preview-url={track.previewUrl}
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="white"
          aria-hidden="true"
        >
          <path d="M8 5v14l11-7z" />
        </svg>
      </button>
    )}
  </ArtworkImage>

  <!-- Track info -->
  <div class="flex min-w-0 flex-1 flex-col">
    <span class="truncate text-sm font-semibold text-[var(--text-primary)]">
      {track.title}
      {track.explicit && (
        <span
          class="ml-1 inline-flex items-center rounded bg-[var(--bg-overlay)] px-1 py-0.5 align-middle text-[10px] font-bold uppercase leading-none text-[var(--text-muted)]"
          title="Explicit"
        >
          E
        </span>
      )}
    </span>
    <a
      href={`/ChartWave-Global-Music-Charts-PWA/artist/${track.artistSlug}`}
      class="truncate text-sm text-[var(--text-secondary)] transition-colors hover:text-[var(--text-accent)]"
    >
      {track.artistName}
    </a>
  </div>

  <!-- Genre tags (hidden on mobile) -->
  {genreTags.length > 0 && (
    <div class="hidden shrink-0 items-center gap-1.5 md:flex">
      {genreTags.map((genre) => (
        <span class="rounded-full bg-[var(--bg-elevated)] px-2 py-0.5 text-xs text-[var(--text-secondary)] border border-[var(--border-subtle)]">
          {genre}
        </span>
      ))}
    </div>
  )}

  <!-- Listeners count (hidden on small screens) -->
  <span class="hidden shrink-0 text-sm text-[var(--text-muted)] lg:block" title={`${track.listeners.toLocaleString()} listeners`}>
    {formatNumber(track.listeners)}
  </span>

  <!-- Context menu button -->
  <button
    type="button"
    class="shrink-0 rounded-md p-1 text-[var(--text-muted)] opacity-0 transition-all hover:bg-[var(--bg-elevated)] hover:text-[var(--text-secondary)] group-hover:opacity-100"
    aria-label={`More options for ${track.title}`}
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <circle cx="12" cy="5" r="2" />
      <circle cx="12" cy="12" r="2" />
      <circle cx="12" cy="19" r="2" />
    </svg>
  </button>
</div>
