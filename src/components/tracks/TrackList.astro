---
import type { Track } from '../../content/config';
import TrackRow from './TrackRow.astro';

interface Props {
  tracks: Track[];
  showHeader?: boolean;
}

const { tracks, showHeader = false } = Astro.props;
---

<div class="w-full" role="table" aria-label="Track chart">
  {showHeader && (
    <div
      class="flex items-center gap-3 border-b border-[var(--border-subtle)] px-3 py-2 text-xs font-medium uppercase tracking-wider text-[var(--text-muted)]"
      role="row"
    >
      <span class="w-12 shrink-0 text-right">#</span>
      <span class="w-12 shrink-0 text-center">Change</span>
      <span class="w-12 shrink-0">&nbsp;</span>
      <span class="min-w-0 flex-1">Title</span>
      <span class="hidden shrink-0 md:block">Genre</span>
      <span class="hidden shrink-0 lg:block">Listeners</span>
      <span class="w-7 shrink-0">&nbsp;</span>
    </div>
  )}

  <div class="divide-y divide-[var(--border-subtle)]" role="rowgroup">
    {tracks.map((track, i) => (
      <TrackRow track={track} index={i} />
    ))}
  </div>

  {tracks.length === 0 && (
    <div class="flex items-center justify-center py-12 text-sm text-[var(--text-muted)]">
      No tracks to display.
    </div>
  )}
</div>
