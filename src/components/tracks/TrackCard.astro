---
import type { Track } from '../../content/config';
import { formatNumber } from '@utils/format';
import RankBadge from './RankBadge.astro';
import ArtworkImage from './ArtworkImage.astro';

interface Props {
  track: Track;
}

const { track } = Astro.props;

const rankDisplay = String(track.rank).padStart(3, '0');
const hasPreview = track.previewUrl !== null;
---

<div
  class="group relative overflow-hidden rounded-xl bg-[var(--bg-surface)] border border-[var(--border-subtle)] p-4 transition-all duration-300 hover:border-[var(--border-accent)] hover:shadow-lg hover:shadow-[var(--brand)]/5"
  data-track-id={track.id}
>
  <!-- Rank badge in top-right corner -->
  <div class="absolute top-3 right-3 z-10 flex items-center gap-1.5 rounded-full bg-[var(--bg-overlay)]/80 px-2.5 py-1 backdrop-blur-sm">
    <span class="font-mono text-xs font-bold text-[var(--text-muted)]">{rankDisplay}</span>
    <RankBadge rankChange={track.rankChange} rankDelta={track.rankDelta} />
  </div>

  <!-- Large artwork -->
  <div class="relative mb-4 aspect-square overflow-hidden rounded-lg">
    <img
      src={track.artwork.large}
      alt={`${track.title} by ${track.artistName}`}
      width="300"
      height="300"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      style={track.artwork.placeholder ? `background-color: ${track.artwork.placeholder};` : 'background-color: var(--bg-elevated);'}
      onerror="this.style.display='none'"
    />

    {/* Play overlay on hover */}
    {hasPreview && (
      <button
        type="button"
        class="absolute inset-0 flex items-center justify-center bg-black/50 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        aria-label={`Play preview of ${track.title}`}
        data-preview-url={track.previewUrl}
      >
        <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--brand)] shadow-lg transition-transform group-hover:scale-110">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="white"
            aria-hidden="true"
          >
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </button>
    )}
  </div>

  <!-- Track title -->
  <h3 class="truncate text-base font-semibold text-[var(--text-primary)] group-hover:text-[var(--text-accent)] transition-colors">
    {track.title}
    {track.explicit && (
      <span
        class="ml-1 inline-flex items-center rounded bg-[var(--bg-overlay)] px-1 py-0.5 align-middle text-[10px] font-bold uppercase leading-none text-[var(--text-muted)]"
        title="Explicit"
      >
        E
      </span>
    )}
  </h3>

  <!-- Artist name -->
  <a
    href={`/ChartWave-Global-Music-Charts-PWA/artist/${track.artistSlug}`}
    class="mt-1 block truncate text-sm text-[var(--text-secondary)] transition-colors hover:text-[var(--text-accent)]"
  >
    {track.artistName}
  </a>

  <!-- Footer: listeners + genres -->
  <div class="mt-3 flex items-center justify-between gap-2">
    <span class="text-xs text-[var(--text-muted)]" title={`${track.listeners.toLocaleString()} listeners`}>
      {formatNumber(track.listeners)} listeners
    </span>

    {track.genres.length > 0 && (
      <span class="truncate rounded-full bg-[var(--bg-elevated)] px-2 py-0.5 text-xs text-[var(--text-secondary)] border border-[var(--border-subtle)]">
        {track.genres[0]}
      </span>
    )}
  </div>
</div>
