---
import Button from '../ui/Button.astro';
---

<section class="relative mesh-bg min-h-[80dvh] flex items-center justify-center overflow-hidden">
  <!-- Extra ambient glow layers -->
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    aria-hidden="true"
  >
    <div class="absolute left-1/2 top-1/3 h-[500px] w-[700px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--brand)]/8 blur-[120px]"></div>
    <div class="absolute right-1/4 bottom-1/4 h-[300px] w-[400px] rounded-full bg-[var(--brand-alt)]/6 blur-[100px]"></div>
  </div>

  <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
    <!-- Animated badge -->
    <div class="mb-8 animate-fade-in">
      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--border-accent)] bg-[var(--brand)]/5 px-4 py-1.5 text-xs font-medium text-[var(--text-accent)]">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--brand)] opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--brand)]"></span>
        </span>
        Daily updated &middot; Free &middot; Open Source &middot; No account needed
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-balance text-4xl font-bold tracking-tight text-[var(--text-primary)] sm:text-5xl lg:text-7xl animate-slide-down">
      The world's charts.
      <br />
      <span class="gradient-text">Free to play.</span>
    </h1>

    <!-- Subtext -->
    <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--text-secondary)] text-pretty sm:text-xl animate-fade-in">
      Stream 30-second previews of the most popular tracks from around the globe.
      No sign-up required. Updated daily from Last.fm, iTunes, and MusicBrainz.
    </p>

    <!-- CTA buttons -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row animate-fade-in">
      <Button variant="primary" size="lg" href="/chartwave/chart/global-top50">
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.344-5.891a1.5 1.5 0 000-2.538L6.3 2.841z" />
        </svg>
        Play Global Top 50
      </Button>
      <Button variant="outline" size="lg" href="/chartwave/charts">
        Browse All Charts
      </Button>
    </div>
  </div>
</section>
