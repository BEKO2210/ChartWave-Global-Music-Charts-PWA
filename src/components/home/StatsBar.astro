---
import { getCollection } from 'astro:content';
import { formatRelativeDate } from '@utils/format';
import type { Chart } from '../../content/config';

// Compute stats dynamically from actual chart data
const entries = await getCollection('charts');
const allCharts: Chart[] = entries
  .filter((e) => e.id !== 'meta')
  .map((e) => e.data as unknown as Chart);

const totalCharts = allCharts.length;
const totalTracks = allCharts.reduce((sum, c) => sum + c.tracks.length, 0);

// Find the most recent lastUpdated across all charts
const latestUpdate = allCharts.reduce((latest, c) => {
  return c.lastUpdated > latest ? c.lastUpdated : latest;
}, '');

const stats = [
  { label: 'Tracks', value: `${totalTracks}` },
  { label: 'Charts', value: `${totalCharts}` },
  { label: 'Last updated', value: latestUpdate ? formatRelativeDate(latestUpdate) : 'N/A' },
];
---

<section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
    {stats.map((stat, i) => (
      <>
        <div class="flex flex-col items-center rounded-xl bg-[var(--bg-surface)] border border-[var(--border-subtle)] px-6 py-4 min-w-[140px]">
          <span class="text-2xl font-bold text-[var(--text-primary)]">{stat.value}</span>
          <span class="text-xs text-[var(--text-muted)] mt-1">{stat.label}</span>
        </div>
        {i < stats.length - 1 && (
          <span class="hidden sm:block text-[var(--text-muted)]" aria-hidden="true">&middot;</span>
        )}
      </>
    ))}
  </div>
</section>
